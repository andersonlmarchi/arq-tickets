# Variaveis carregadas pelo docker compose a partir de /.env (env_file).
# Referencia: ../.env.example na raiz do monorepo.

APP_NAME=sales-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres-sales
DB_PORT=5432
DB_DATABASE=sales_db
DB_USERNAME=sales
DB_PASSWORD=sales_secret

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

CATALOG_SERVICE_URL=http://catalog-service:8000
CATALOG_API_KEY=dev-shared-key-change-me
CATALOG_HTTP_TIMEOUT_MS=2000
CATALOG_HTTP_RETRY_COUNT=1

PAGAMENTO_PRAZO_SEGUNDOS=30
PAGAMENTO_MAX_ERROS_CHAVE=3

CORS_ALLOWED_ORIGINS=http://localhost:5173
