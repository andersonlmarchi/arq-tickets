# Copie para .env na raiz: cp .env.example .env
# O docker compose carrega este arquivo em todos os containers (env_file).

COMPOSE_PROJECT_NAME=arq-tickets

# --- PostgreSQL catálogo (container postgres-catalog) ---
POSTGRES_CATALOG_USER=catalog
POSTGRES_CATALOG_PASSWORD=catalog_secret
POSTGRES_CATALOG_DB=catalog_db

# --- PostgreSQL vendas (container postgres-sales) ---
POSTGRES_SALES_USER=sales
POSTGRES_SALES_PASSWORD=sales_secret
POSTGRES_SALES_DB=sales_db

# --- catalog-service (FastAPI) ---
DATABASE_URL=postgresql+psycopg2://catalog:catalog_secret@postgres-catalog:5432/catalog_db
API_KEY=dev-shared-key-change-me
LOG_LEVEL=INFO

# --- sales-service (Laravel) ---
APP_NAME=sales-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
LOG_CHANNEL=stderr

DB_CONNECTION=pgsql
DB_HOST=postgres-sales
DB_PORT=5432
DB_DATABASE=sales_db
DB_USERNAME=sales
DB_PASSWORD=sales_secret

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

CATALOG_SERVICE_URL=http://catalog-service:8000
CATALOG_API_KEY=dev-shared-key-change-me
CATALOG_HTTP_TIMEOUT_MS=2000
CATALOG_HTTP_RETRY_COUNT=1

PAGAMENTO_PRAZO_SEGUNDOS=30
PAGAMENTO_MAX_ERROS_CHAVE=3

CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- frontend (proxima etapa) ---
# VITE_SALES_API_URL=http://localhost:8080
